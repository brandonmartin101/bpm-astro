---
import '../styles/global.scss';
import Helmet from '../components/Helmet.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, favicon: customFavicon } = Astro.props;
const { addScript } = Astro.props;

const logoSeed = Math.floor(Math.random() * 20);
const logo = `/avatars/avatar-${logoSeed}.svg`;
const favicon = customFavicon || logo;
---

<html lang='en' data-theme='light' transition:persist>
	<Helmet title={`Brandon Martin | ${title}`} favicon={favicon} addScript={addScript} />
	<body>
		<Header logo={logo} />
		<main class='main'>
			<slot />
		</main>
		<Footer />
	</body>
</html>
